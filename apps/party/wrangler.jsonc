{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rebtel-atelier",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "Canvas",
        "class_name": "Canvas"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Canvas"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
