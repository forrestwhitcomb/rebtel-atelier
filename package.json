{
  "name": "rebtel-atelier",
  "version": "0.0.0",
  "private": true,
  "description": "Rebtel Atelier — design system workbench with live prototyping.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @rebtel-atelier/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "verify": "node scripts/verify-no-hex.mjs",
    "deploy:party": "pnpm --filter @rebtel-atelier/party run deploy"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  }
}
